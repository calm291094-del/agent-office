{
  "name": "agent-office",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "echo 'No build needed'",
    "start:server": "node packages/server/index.js",
    "start:ui": "node packages/ui/server.js"
  },
  "engines": {
    "node": ">=18"
  }
}
{
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "node standalone-server/index.js",
    "dev:ui": "cd webview-ui && npm run dev",
    "build": "npm run build:ui",
    "build:ui": "cd webview-ui && npm run build",
    "start": "node standalone-server/index.js",
    "setup": "npm install && cd webview-ui && npm install"
  }
}
