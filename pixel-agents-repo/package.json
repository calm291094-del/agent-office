{
  "name": "pixel-agents-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "node standalone-server/index.js",
    "dev:ui": "cd webview-ui && npm run dev",
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "cd webview-ui && npm run build",
    "build:server": "echo 'Server no necesita build'",
    "start": "node standalone-server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "concurrently": "^8.0.0"
  },
  "workspaces": [
    "webview-ui",
    "server"
  ]
}
