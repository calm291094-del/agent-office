{
  "name": "pixel-agents-repo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "core",
    "server",
    "webview-ui"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:server && npm run build:webview",
    "build:core": "cd core && npm run build",
    "build:server": "cd server && npm run build",
    "build:webview": "cd webview-ui && npm run build",
    "start": "node dist/cli.js --port $PORT --host 0.0.0.0",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:webview\"",
    "dev:server": "cd server && npm run dev",
    "dev:webview": "cd webview-ui && npm run dev"
  },
  "dependencies": {
    "concurrently": "^8.0.0"
  }
}
